{
  "extends": "tsconfig-shared/electron.json",
  "compilerOptions": {
    "composite": true,
    "noEmit": true,
    "baseUrl": ".",
    "paths": {
      "@lib/*": ["src/lib/*"],
      "@core/*": ["src/core/*"],
      "@services/*": ["src/services/*"],
      "@trpc/*": ["src/trpc/*"],
      "@/*": ["src/*"],
    },
    "types": ["node"],
    "outDir": "dist",
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist"]
}
