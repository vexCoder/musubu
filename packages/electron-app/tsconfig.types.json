{
  "compilerOptions": {
    "baseUrl": ".",
    "composite": true,
    "declaration": true,
    "declarationMap": true,
    "emitDeclarationOnly": true,
    "outDir": "dist-types",
    "paths": {
      "@/*": ["src/*"],
      "@lib/*": ["src/lib/*"],
      "@core/*": ["src/core/*"],
      "@services/*": ["src/services/*"],
      "@trpc/*": ["src/trpc/*"],
    },
    "target": "es6",
    "types": [
      "node"
    ]
  },
  "exclude": [
    "node_modules",
    "dist"
  ],
  "extends": "tsconfig-shared/electron.json",
  "include": [
    "src/**/*"
  ]
}