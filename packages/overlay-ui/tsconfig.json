{
  "extends": "tsconfig-shared/react.json",
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"],
      "@/": ["src/"],
      "@/pages/*": ["src/pages/*"],
      "@/pages/": ["src/pages/"],
      "@/lib/*": ["src/lib/*"],
      "@/lib/": ["src/lib/"],
    },
    "types": ["node", "vite/client"]
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist", "vite.config.mts"]
}
